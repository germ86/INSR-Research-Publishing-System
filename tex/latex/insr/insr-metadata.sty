\NewDocumentCommand \INSRAddInstitution { m }
  { \tl_clear:N\l_insr_institution_id_tl \tl_clear:N\l_insr_institution_name_tl \tl_clear:N\l_insr_institution_department_tl \tl_clear:N\l_insr_institution_city_tl \tl_clear:N\l_insr_institution_country_tl \tl_clear:N\l_insr_institution_ror_tl \keys_set:nn { insr/institution } { #1 } \prop_gput:Nxx \g_insr_institution_name_prop { \tl_use:N \l_insr_institution_id_tl } { \tl_use:N \l_insr_institution_name_tl } \seq_gput_right:Nx \g_insr_institution_seq { \tl_use:N\l_insr_institution_name_tl } }
\NewDocumentCommand \INSRAddAuthor { m }
  { \tl_clear:N\l_insr_author_name_tl \tl_clear:N\l_insr_author_short_name_tl \tl_clear:N\l_insr_author_orcid_tl \tl_clear:N\l_insr_author_email_tl \tl_clear:N\l_insr_author_affiliations_tl \tl_clear:N\l_insr_author_roles_tl \keys_set:nn { insr/author } { #1 } \seq_gput_right:Nx \g_insr_author_name_seq { \tl_use:N\l_insr_author_name_tl } \seq_gput_right:Nx \g_insr_author_short_seq { \tl_if_blank:VTF \l_insr_author_short_name_tl { \tl_use:N\l_insr_author_name_tl } { \tl_use:N\l_insr_author_short_name_tl } } \seq_gput_right:Nx \g_insr_author_orcid_seq { \tl_use:N\l_insr_author_orcid_tl } \seq_gput_right:Nx \g_insr_author_affiliation_seq { \clist_map_function:NN \l_insr_author_affiliations_tl \__insr_affiliation_label:n } \seq_gput_right:Nx \g_insr_author_credit_seq { \tl_use:N \l_insr_author_roles_tl } \seq_gput_right:Nx \g_insr_author_seq { \tl_use:N\l_insr_author_name_tl } }
\NewDocumentCommand \INSRAddFunding { m } { \keys_set:nn { insr/funding } { #1 } \seq_gput_right:Nx \g_insr_funding_seq { \tl_use:N\l_insr_funding_agency_tl~\tl_use:N\l_insr_funding_grant_tl~\tl_use:N\l_insr_funding_project_tl } \tl_gset:Nx \g_insr_funding_statement_tl { \seq_use:Nn \g_insr_funding_seq {;~} } }
\NewDocumentCommand \INSRAuthor { O{} m m O{} O{} } { \msg_warning:nnn { insr } { deprecated-command } { \string\INSRAuthor } \tl_gset:Nn \g_insr_author_tl { #2 } \tl_gset:Nn \g_insr_institution_tl { #3 } \seq_gput_right:Nn \g_insr_author_seq { #2 } }
\NewDocumentCommand \INSRInstitution { O{} m O{} } { \msg_warning:nnn { insr } { deprecated-command } { \string\INSRInstitution } \tl_gset:Nn \g_insr_institution_tl { #2 } \seq_gput_right:Nn \g_insr_institution_seq { #2 } }
\NewDocumentCommand \INSRLogo { O{} m m } { }
\cs_new:Npn \insr_author_block: { \seq_if_empty:NTF \g_insr_author_name_seq { \tl_use:N \g_insr_author_tl } { \seq_use:Nn \g_insr_author_name_seq {,~} } }
\cs_new:Npn \insr_institution_block: { \seq_if_empty:NTF \g_insr_institution_seq { \tl_use:N \g_insr_institution_tl } { \seq_use:Nn \g_insr_institution_seq {;~} } }
\cs_new_protected:Npn \insr_author_title_block:
  {
    \seq_if_empty:NTF \g_insr_author_name_seq
      { \tl_use:N \g_insr_author_tl }
      {
        \seq_map_indexed_inline:Nn \g_insr_author_name_seq
          {
            ##2
            \tl_set:Nx \l_tmpa_tl { \seq_item:Nn \g_insr_author_orcid_seq {##1} }
            \tl_if_blank:VF \l_tmpa_tl {~(ORCID:~\href{https://orcid.org/\tl_use:N\l_tmpa_tl}{\tl_use:N\l_tmpa_tl})}
            \int_compare:nNnT {##1} < {\seq_count:N \g_insr_author_name_seq} {;~}
          }
      }
  }
\cs_new_protected:Npn \insr_affiliation_title_block:
  { \seq_if_empty:NTF \g_insr_author_affiliation_seq { \insr_institution_block: } { \seq_remove_duplicates:N \g_insr_author_affiliation_seq \seq_use:Nn \g_insr_author_affiliation_seq {;~} } }


\cs_new_protected:Npn \insr_credit_block:
  {
    \tl_if_blank:VTF \g_insr_author_contributions_tl
      {
        \int_zero:N \l__insr_credit_author_index_int
        \bool_set_false:N \l__insr_credit_output_started_bool
        \seq_map_inline:Nn \g_insr_author_credit_seq
          {
            \int_incr:N \l__insr_credit_author_index_int
            \__insr_roles_has_valid:nT {##1}
              {
                \bool_if:NT \l__insr_credit_output_started_bool {;~}
                \__insr_credit_author_line:n {\int_use:N \l__insr_credit_author_index_int}
                \bool_set_true:N \l__insr_credit_output_started_bool
              }
          }
      }
      { \tl_use:N \g_insr_author_contributions_tl }
  }




\cs_new_protected:Npn \__insr_citation_doi_valid_set:
  {
    \bool_set_false:N \l__insr_citation_doi_valid_bool
    \tl_if_blank:VF \g_insr_publication_doi_tl
      {
        \tl_set_eq:NN \l_tmpa_tl \g_insr_publication_doi_tl
        \tl_trim_spaces:N \l_tmpa_tl
        \str_if_eq:VnF \l_tmpa_tl { pending }
          { \str_if_eq:VnF \l_tmpa_tl { to~be~assigned } { \bool_set_true:N \l__insr_citation_doi_valid_bool } }
      }
  }

\cs_new_protected:Npn \insr_suggested_citation:
  {
    \str_if_eq:VnTF \g_insr_citation_mode_tl { manual }
      { \tl_if_blank:VTF \g_insr_suggested_citation_tl { \tl_use:N \g_insr_citation_tl } { \tl_use:N \g_insr_suggested_citation_tl } }
      {
        \seq_if_empty:NTF \g_insr_author_short_seq { \tl_use:N \g_insr_author_tl } { \seq_use:Nn \g_insr_author_short_seq {;~} }\space
        (\tl_if_blank:VTF \g_insr_publication_year_tl {2026} {\tl_use:N \g_insr_publication_year_tl}).\space
        \tl_use:N \g_insr_title_tl
        \tl_if_blank:VF \g_insr_subtitle_tl {:~\tl_use:N \g_insr_subtitle_tl}
        \tl_if_blank:VF \g_insr_publication_version_tl {~(Version~\tl_use:N \g_insr_publication_version_tl)}.\space
        \tl_if_blank:VTF \g_insr_publication_publisher_tl { \tl_use:N \g_insr_institution_tl } { \tl_use:N \g_insr_publication_publisher_tl }.
        \__insr_citation_doi_valid_set:
        \bool_if:NT \l__insr_citation_doi_valid_bool {~\href{https://doi.org/\tl_use:N\g_insr_publication_doi_tl}{https://doi.org/\tl_use:N\g_insr_publication_doi_tl}.}
      }
  }
