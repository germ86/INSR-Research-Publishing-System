\msg_new:nnn { insr } { unknown-credit-role } { Unknown~CRediT~role~'#1';~omitting~technical~slug~from~PDF. }
\cs_new_protected:Npn \__insr_credit_role_label_set:n #1
  {
    \bool_set_false:N \l__insr_credit_role_valid_bool
    \tl_clear:N \l__insr_credit_role_label_tl
    \tl_set:Nn \l__insr_credit_role_key_tl {#1}
    \tl_trim_spaces:N \l__insr_credit_role_key_tl
    \str_case:VnTF \l__insr_credit_role_key_tl
      {
        {conceptualization}{\tl_set:Nn \l__insr_credit_role_label_tl {Conceptualization}}
        {methodology}{\tl_set:Nn \l__insr_credit_role_label_tl {Methodology}}
        {software}{\tl_set:Nn \l__insr_credit_role_label_tl {Software}}
        {writing-original-draft}{\tl_set:Nn \l__insr_credit_role_label_tl {Writing~--~Original~Draft}}
        {writing-review-editing}{\tl_set:Nn \l__insr_credit_role_label_tl {Writing~--~Review~\&~Editing}}
        {investigation}{\tl_set:Nn \l__insr_credit_role_label_tl {Investigation}}
        {validation}{\tl_set:Nn \l__insr_credit_role_label_tl {Validation}}
        {visualization}{\tl_set:Nn \l__insr_credit_role_label_tl {Visualization}}
        {formal-analysis}{\tl_set:Nn \l__insr_credit_role_label_tl {Formal~Analysis}}
        {data-curation}{\tl_set:Nn \l__insr_credit_role_label_tl {Data~Curation}}
        {project-administration}{\tl_set:Nn \l__insr_credit_role_label_tl {Project~Administration}}
        {supervision}{\tl_set:Nn \l__insr_credit_role_label_tl {Supervision}}
        {funding-acquisition}{\tl_set:Nn \l__insr_credit_role_label_tl {Funding~Acquisition}}
        {resources}{\tl_set:Nn \l__insr_credit_role_label_tl {Resources}}
      }
      { \bool_set_true:N \l__insr_credit_role_valid_bool }
      {
        \tl_if_blank:VF \l__insr_credit_role_key_tl
          { \str_if_eq:VnT \g_insr_build_profile_tl { development } { \msg_warning:nnx { insr } { unknown-credit-role } { \tl_use:N \l__insr_credit_role_key_tl } } }
      }
  }
\cs_new_protected:Npn \__insr_credit_role_collect:n #1
  {
    \__insr_credit_role_label_set:n {#1}
    \bool_if:NT \l__insr_credit_role_valid_bool
      { \seq_put_right:Nx \l__insr_credit_role_label_seq { \tl_use:N \l__insr_credit_role_label_tl } }
  }
\cs_new_protected:Npn \__insr_roles_label:n #1
  {
    \seq_clear:N \l__insr_credit_role_label_seq
    \clist_set:Nn \l_tmpa_clist {#1}
    \clist_map_function:NN \l_tmpa_clist \__insr_credit_role_collect:n
    \seq_use:Nn \l__insr_credit_role_label_seq {,~}
  }
\prg_new_conditional:Npnn \__insr_roles_has_valid:n #1 { T, F, TF }
  {
    \seq_clear:N \l__insr_credit_role_label_seq
    \clist_set:Nn \l_tmpa_clist {#1}
    \clist_map_function:NN \l_tmpa_clist \__insr_credit_role_collect:n
    \seq_if_empty:NTF \l__insr_credit_role_label_seq { \prg_return_false: } { \prg_return_true: }
  }

\cs_new_protected:Npn \__insr_credit_author_line:n #1
  {
    \tl_set:Nx \l_tmpa_tl { \seq_item:Nn \g_insr_author_name_seq {#1} }
    \tl_if_blank:VF \l_tmpa_tl { \textbf{\tl_use:N \l_tmpa_tl}:~ }
    \seq_use:Nn \l__insr_credit_role_label_seq {,~}
  }
\prg_new_conditional:Npnn \insr_credit_has_valid: { T, F, TF }
  {
    \bool_set_false:N \l_tmpa_bool
    \seq_map_inline:Nn \g_insr_author_credit_seq
      { \__insr_roles_has_valid:nT {##1} { \bool_set_true:N \l_tmpa_bool } }
    \bool_if:NTF \l_tmpa_bool { \prg_return_true: } { \prg_return_false: }
  }
