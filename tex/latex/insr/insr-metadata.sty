\NewDocumentCommand \INSRAddInstitution { m }
  {
    \group_begin:
    \tl_clear:N \l__insr_registry_id_tl
    \tl_clear:N \l__insr_registry_name_tl
    \tl_clear:N \l__insr_registry_short_name_tl
    \tl_clear:N \l__insr_registry_type_tl
    \keys_set:nn { insr/institution } { #1 }
    \seq_gput_right:NV \g_insr_institution_id_seq \l__insr_registry_id_tl
    \prop_gput:NVV \g_insr_institution_name_prop \l__insr_registry_id_tl \l__insr_registry_name_tl
    \prop_gput:NVV \g_insr_institution_short_name_prop \l__insr_registry_id_tl \l__insr_registry_short_name_tl
    \prop_gput:NVV \g_insr_institution_type_prop \l__insr_registry_id_tl \l__insr_registry_type_tl
    \group_end:
  }
\NewDocumentCommand \INSRAddAuthor { m }
  {
    \group_begin:
    \tl_clear:N \l__insr_registry_id_tl
    \tl_clear:N \l__insr_registry_name_tl
    \tl_clear:N \l__insr_registry_short_name_tl
    \tl_clear:N \l__insr_registry_orcid_tl
    \tl_clear:N \l__insr_registry_affiliations_tl
    \tl_clear:N \l__insr_registry_roles_tl
    \keys_set:nn { insr/author } { #1 }
    \seq_gput_right:NV \g_insr_author_id_seq \l__insr_registry_id_tl
    \prop_gput:NVV \g_insr_author_name_prop \l__insr_registry_id_tl \l__insr_registry_name_tl
    \prop_gput:NVV \g_insr_author_short_name_prop \l__insr_registry_id_tl \l__insr_registry_short_name_tl
    \prop_gput:NVV \g_insr_author_orcid_prop \l__insr_registry_id_tl \l__insr_registry_orcid_tl
    \prop_gput:NVV \g_insr_author_affiliations_prop \l__insr_registry_id_tl \l__insr_registry_affiliations_tl
    \prop_gput:NVV \g_insr_author_roles_prop \l__insr_registry_id_tl \l__insr_registry_roles_tl
    \tl_if_blank:VTF \l__insr_registry_short_name_tl
      { \seq_gput_right:NV \g_insr_author_short_seq \l__insr_registry_name_tl }
      { \seq_gput_right:NV \g_insr_author_short_seq \l__insr_registry_short_name_tl }
    \group_end:
  }
\cs_new:Npn \insr_author_block:
  {
    \seq_if_empty:NTF \g_insr_author_id_seq
      { \tl_use:N \g_insr_author_tl }
      {
        \seq_map_indexed_inline:Nn \g_insr_author_id_seq
          {
            \int_compare:nNnT {##1} > {1} {,~}
            \prop_item:Nn \g_insr_author_name_prop {##2}
            \tl_set:Nx \l_tmpa_tl { \prop_item:Nn \g_insr_author_orcid_prop {##2} }
            \tl_if_blank:VF \l_tmpa_tl {~(ORCID:~\l_tmpa_tl)}
          }
      }
  }
\cs_new:Npn \insr_institution_block:
  {
    \seq_if_empty:NTF \g_insr_institution_id_seq
      { \tl_use:N \g_insr_institution_tl }
      { \seq_use:Nn \g_insr_institution_id_seq {;~} }
  }
\msg_new:nnn { insr } { unknown-credit-role } { Unknown~CRediT~role~'#1';~omitting~technical~slug~from~PDF. }
\cs_new_protected:Npn \__insr_roles_label:n #1
  {
    \tl_clear:N \l__insr_roles_label_tl
    \clist_set:Nn \l_tmpa_clist {#1}
    \clist_map_indexed_inline:Nn \l_tmpa_clist
      {
        \prop_get:NnNTF \g__insr_credit_role_label_prop {##2} \l_tmpa_tl
          {
            \int_compare:nNnT {##1} > {1} { \tl_put_right:Nn \l__insr_roles_label_tl {,~} }
            \tl_put_right:NV \l__insr_roles_label_tl \l_tmpa_tl
          }
          { \msg_warning:nnn { insr } { unknown-credit-role } {##2} }
      }
  }
\prg_new_conditional:Npnn \__insr_roles_has_valid:n #1 { T, F, TF }
  {
    \__insr_roles_label:n {#1}
    \tl_if_blank:VTF \l__insr_roles_label_tl { \prg_return_false: } { \prg_return_true: }
  }
\cs_new_protected:Npn \__insr_credit_author_line:n #1
  {
    \tl_set:Nx \l_tmpa_tl { \seq_item:Nn \g_insr_author_id_seq {#1} }
    \prop_item:NV \g_insr_author_name_prop \l_tmpa_tl :~
    \prop_get:NVN \g_insr_author_roles_prop \l_tmpa_tl \l_tmpb_tl
    \__insr_roles_label:n {\l_tmpb_tl}
    \tl_use:N \l__insr_roles_label_tl
  }
\cs_new_protected:Npn \insr_author_contributions:
  {
    \seq_if_empty:NTF \g_insr_author_id_seq
      { \tl_use:N \g_insr_author_contributions_tl }
      {
        \bool_set_false:N \l__insr_credit_output_started_bool
        \int_zero:N \l__insr_credit_author_index_int
        \seq_map_inline:Nn \g_insr_author_id_seq
          {
            \int_incr:N \l__insr_credit_author_index_int
            \prop_get:NnN \g_insr_author_roles_prop {##1} \l_tmpa_tl
            \__insr_roles_has_valid:nT {\l_tmpa_tl}
              {
                \bool_if:NT \l__insr_credit_output_started_bool {;~}
                \__insr_credit_author_line:n {\int_use:N \l__insr_credit_author_index_int}
                \bool_set_true:N \l__insr_credit_output_started_bool
              }
          }
      }
  }
\cs_new_protected:Npn \__insr_citation_doi_valid_set:
  {
    \bool_set_false:N \l__insr_citation_doi_valid_bool
    \tl_if_blank:VF \g_insr_publication_doi_tl
      {
        \tl_set_eq:NN \l_tmpa_tl \g_insr_publication_doi_tl
        \tl_trim_spaces:N \l_tmpa_tl
        \str_if_eq:VnF \l_tmpa_tl { pending }
          { \str_if_eq:VnF \l_tmpa_tl { to~be~assigned } { \bool_set_true:N \l__insr_citation_doi_valid_bool } }
      }
  }
\cs_new_protected:Npn \insr_suggested_citation:
  {
    \str_if_eq:VnTF \g_insr_citation_mode_tl { manual }
      { \tl_if_blank:VTF \g_insr_suggested_citation_tl { \tl_use:N \g_insr_citation_tl } { \tl_use:N \g_insr_suggested_citation_tl } }
      {
        \seq_if_empty:NTF \g_insr_author_short_seq { \tl_use:N \g_insr_author_tl } { \seq_use:Nn \g_insr_author_short_seq {;~} }\space
        (\tl_if_blank:VTF \g_insr_publication_year_tl {\number\year} {\tl_use:N \g_insr_publication_year_tl}).\space
        \tl_use:N \g_insr_title_tl
        \tl_if_blank:VF \g_insr_subtitle_tl {:~\tl_use:N \g_insr_subtitle_tl}
        \tl_if_blank:VF \g_insr_publication_version_tl {~(Version~\tl_use:N \g_insr_publication_version_tl)}.\space
        \tl_if_blank:VTF \g_insr_publication_publisher_tl { \tl_use:N \g_insr_institution_tl } { \tl_use:N \g_insr_publication_publisher_tl }.
        \__insr_citation_doi_valid_set:
        \bool_if:NT \l__insr_citation_doi_valid_bool {~\href{https://doi.org/\tl_use:N\g_insr_publication_doi_tl}{https://doi.org/\tl_use:N\g_insr_publication_doi_tl}.}
      }
  }
\cs_new_protected:Npn \__insr_setup_pdf_metadata:
  {
    \tl_set_eq:NN \l__insr_pdf_title_tl \g_insr_title_tl
    \tl_set:Nx \l__insr_pdf_author_tl { \insr_author_block: }
    \tl_set_eq:NN \l__insr_pdf_keywords_tl \g_insr_keywords_tl
    \exp_args:Nx \hypersetup
      {
        unicode=true,
        colorlinks=true,
        linkcolor=INSRLink,
        citecolor=INSRLink,
        urlcolor=INSRLink,
        pdftitle={\tl_use:N\l__insr_pdf_title_tl},
        pdfauthor={\tl_use:N\l__insr_pdf_author_tl},
        pdfsubject={\tl_use:N\g_insr_publication_type_tl;~\tl_use:N\g_insr_publication_status_tl},
        pdfkeywords={\tl_use:N\l__insr_pdf_keywords_tl},
        pdflang={\tl_use:N\g_insr_language_tl},
        pdfcreator={INSR Scientific Publishing Platform},
        pdfproducer={LuaLaTeX with INSR},
        pdfinfo={doi={\tl_use:N\g_insr_publication_doi_tl},License={\tl_use:N\g_insr_publication_license_tl},Repository={\tl_use:N\g_insr_publication_repository_tl},Version={\tl_use:N\g_insr_publication_version_tl},PublicationStatus={\tl_use:N\g_insr_publication_status_tl}}
      }
  }
