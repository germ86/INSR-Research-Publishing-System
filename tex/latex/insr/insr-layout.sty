\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{insr-layout}[2026/07/15 INSR layout]
\RequirePackage{graphicx}
\RequirePackage{booktabs,tabularx,longtable,array}
\RequirePackage{amsmath,amssymb,mathtools}
\RequirePackage{microtype}
\RequirePackage{hyperref}
\RequirePackage[acronym,shortcuts]{glossaries-extra}
\RequirePackage{tikz}
\ExplSyntaxOn
\str_if_eq:VnF \g_insr_base_class_tl { beamer }
  { \RequirePackage[a4paper,margin=2.7cm]{geometry} \RequirePackage[automark]{scrlayer-scrpage} \RequirePackage{lastpage} }
\cs_new_protected:Npn \__insr_load_theme:
  {
    \__insr_load_file_with_fallback:nnn
      { themes/\tl_use:N\g_insr_theme_tl.tex }
      { theme }
      {
        \msg_warning:nnx { insr } { unknown-theme } { \tl_use:N\g_insr_theme_tl }
        \file_input:n { themes/insr-default.tex }
      }
  }
\__insr_load_theme:
\__insr_select_language:

\tl_new:N \l__insr_layout_placeholder_tl
\cs_new:Npn \__insr_layout_placeholder:n #1
  { \tl_set:Nx \l__insr_layout_placeholder_tl {#1} \str_case:VnF \l__insr_layout_placeholder_tl { {current-section}{\headmark} {running-title}{\INSRRunningTitle} {page-number}{\thepage} {total-pages}{\pageref{LastPage}} {version}{v\tl_use:N\g_insr_publication_version_tl} {doi}{\INSRDOILabel} } {#1} }
\cs_new_protected:Npn \__insr_setup_page_style:
  {
    \str_if_eq:VnF \g_insr_base_class_tl { beamer }
      { \clearpairofpagestyles
        \bool_if:NT \g_insr_layout_header_bool { \ihead{\__insr_layout_placeholder:n {\tl_use:N\g_insr_layout_header_left_tl}} \chead{\__insr_layout_placeholder:n {\tl_use:N\g_insr_layout_header_center_tl}} \ohead{\__insr_layout_placeholder:n {\tl_use:N\g_insr_layout_header_right_tl}} }
        \bool_if:NT \g_insr_layout_footer_bool { \ifoot{\__insr_layout_placeholder:n {\tl_use:N\g_insr_layout_footer_left_tl}} \cfoot{\__insr_layout_placeholder:n {\tl_use:N\g_insr_layout_footer_center_tl}/\__insr_layout_placeholder:n {total-pages}} \ofoot{\__insr_layout_placeholder:n {\tl_use:N\g_insr_layout_footer_right_tl}} }
        \pagestyle{scrheadings} }
  }
\__insr_setup_pdf_metadata:
\__insr_setup_page_style:
\ExplSyntaxOff
\newacronym{insr}{INSR}{Integrative Neuro-Somatic Recalibration}
\newacronym{cdss}{CDSS}{Clinical Decision Support System}
\newacronym{hrv}{HRV}{heart-rate variability}
\newacronym{eda}{EDA}{electrodermal activity}
\endinput
