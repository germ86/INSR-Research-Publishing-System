\cs_new_protected:Npn \__insr_plugin_check_core:n #1
  {
    \prop_get:NnNT \g__insr_plugin_min_core_prop {#1} \l_tmpa_tl
      { \tl_if_blank:VF \l_tmpa_tl { \tl_if_eq:NNF \l_tmpa_tl \c_insr_core_version_tl { \msg_error:nnxx { insr } { plugin-core-version } {#1} {\tl_use:N \l_tmpa_tl} } } }
  }
\cs_new_protected:Npn \__insr_plugin_check_conflicts:n #1
  {
    \prop_get:NnNT \g__insr_plugin_conflicts_prop {#1} \l_tmpa_tl
      { \exp_args:NV \clist_map_inline:nn \l_tmpa_tl { \seq_if_in:NnT \g__insr_plugin_loaded_seq {##1} { \msg_error:nnnn { insr } { plugin-conflict } {#1} {##1} } } }
  }
\cs_new_protected:Npn \__insr_plugin_load_dependencies:n #1
  {
    \prop_get:NnNT \g__insr_plugin_dependencies_prop {#1} \l_tmpa_tl
      {
        \exp_args:NV \clist_map_inline:nn \l_tmpa_tl
          {
            \prop_if_in:NnTF \g__insr_plugin_registry_prop {##1}
              { \insr_plugin_load:n {##1} }
              { \msg_error:nnnn { insr } { plugin-missing-dependency } {#1} {##1} }
          }
      }
  }
\cs_new_protected:Npn \__insr_plugin_run_init:n #1
  { \prop_get:NnNT \g__insr_plugin_init_prop {#1} \l_tmpa_tl { \tl_if_blank:VF \l_tmpa_tl { \use:c { \tl_use:N \l_tmpa_tl } } } }
\cs_new_protected:Npn \insr_plugin_load:n #1
  {
    \seq_if_in:NnTF \g__insr_plugin_loaded_seq {#1}
      { \msg_warning:nnn { insr } { plugin-duplicate } {#1} }
      {
        \seq_if_in:NnTF \g__insr_plugin_loading_seq {#1}
          { \msg_error:nnn { insr } { plugin-cycle } {#1} }
          {
            \prop_if_in:NnTF \g__insr_plugin_registry_prop {#1}
              {
                \seq_gput_right:Nn \g__insr_plugin_loading_seq {#1}
                \__insr_plugin_check_core:n {#1}
                \__insr_plugin_check_conflicts:n {#1}
                \__insr_plugin_load_dependencies:n {#1}
                \seq_gremove_all:Nn \g__insr_plugin_loading_seq {#1}
                \seq_gput_right:Nn \g__insr_plugin_loaded_seq {#1}
                \__insr_plugin_run_init:n {#1}
              }
              {
                \file_if_exist:nTF { plugins/#1.tex }
                  { \file_input:n { plugins/#1.tex } \seq_gput_right:Nn \g__insr_plugin_loaded_seq {#1} }
                  { \msg_warning:nnn { insr } { plugin-unknown } {#1} }
              }
          }
      }
  }
