        \prop_get:NnNT \g__insr_theme_fontset_prop {#1} \l_tmpa_tl { \tl_if_blank:VF \l_tmpa_tl { \tl_gset_eq:NN \g_insr_font_tl \l_tmpa_tl } }
        \prop_get:NnNT \g__insr_theme_header_rule_prop {#1} \l_tmpa_tl { \tl_if_blank:VF \l_tmpa_tl { \tl_gset_eq:NN \g_insr_layout_header_separator_style_tl \l_tmpa_tl } }
        \prop_get:NnNT \g__insr_theme_footer_rule_prop {#1} \l_tmpa_tl { \tl_if_blank:VF \l_tmpa_tl { \tl_gset_eq:NN \g_insr_layout_footer_separator_style_tl \l_tmpa_tl } }
