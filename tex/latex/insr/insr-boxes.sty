\NewDocumentEnvironment{OutcomeBlock}{+b}{\begin{tcolorbox}[title=Outcome]#1\end{tcolorbox}}{}
\NewDocumentEnvironment{LimitationBlock}{+b}{\begin{tcolorbox}[title=Limitation]#1\end{tcolorbox}}{}
\NewDocumentEnvironment{SafetyBox}{+b}{\begin{tcolorbox}[title=Safety]#1\end{tcolorbox}}{}
