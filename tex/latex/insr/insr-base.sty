% INSR base package -- shared research typography, colors and utilities.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{insr-base}[2026/07/14 v0.1 INSR shared LaTeX framework]
\makeatletter

\RequirePackage{ifluatex}
\ifluatex\else
  \PackageError{insr-base}{INSR requires LuaLaTeX}{Select LuaLaTeX in Overleaf or run latexmk -lualatex locally.}
\fi

\newif\ifinsr@blindreview
\newif\ifinsr@rtl
\newif\ifinsr@python
\newif\ifinsr@externalize
\newif\ifinsr@minted
\newif\ifinsr@review
\DeclareOption{blindreview}{\insr@blindreviewtrue}
\DeclareOption{rtl}{\insr@rtltrue}
\DeclareOption{python}{\insr@pythontrue}
\DeclareOption{externalize}{\insr@externalizetrue}
\DeclareOption{minted}{\insr@mintedtrue}
\DeclareOption{review}{\insr@reviewtrue}
\ProcessOptions\relax

\RequirePackage{fontspec}
\defaultfontfeatures{Ligatures=TeX, Scale=MatchLowercase}
\IfFontExistsTF{Libertinus Serif}{\setmainfont{Libertinus Serif}}{\IfFontExistsTF{TeX Gyre Pagella}{\setmainfont{TeX Gyre Pagella}}{}}
\IfFontExistsTF{Fira Sans}{\setsansfont{Fira Sans}}{\IfFontExistsTF{TeX Gyre Heros}{\setsansfont{TeX Gyre Heros}}{}}
\IfFontExistsTF{Fira Code}{\setmonofont{Fira Code}}{\IfFontExistsTF{Latin Modern Mono}{\setmonofont{Latin Modern Mono}}{}}

\RequirePackage{polyglossia}
\setdefaultlanguage{english}
\setotherlanguages{german,arabic,hebrew,french,spanish}
\IfFontExistsTF{Amiri}{\newfontfamily\arabicfont[Script=Arabic,Scale=1.05]{Amiri}}{\IfFontExistsTF{Noto Naskh Arabic}{\newfontfamily\arabicfont[Script=Arabic,Scale=1.05]{Noto Naskh Arabic}}{\newfontfamily\arabicfont{TeX Gyre Pagella}}}
\IfFontExistsTF{Noto Sans Hebrew}{\newfontfamily\hebrewfont[Script=Hebrew,Scale=1.05]{Noto Sans Hebrew}}{\IfFontExistsTF{Noto Serif Hebrew}{\newfontfamily\hebrewfont[Script=Hebrew,Scale=1.05]{Noto Serif Hebrew}}{\newfontfamily\hebrewfont{TeX Gyre Pagella}}}
\ifinsr@rtl\setdefaultlanguage{arabic}\fi

\RequirePackage{xcolor}
\definecolor{INSRNavy}{HTML}{0A2342}
\definecolor{INSRTeal}{HTML}{17A2B8}
\definecolor{INSRAmber}{HTML}{FFC107}
\definecolor{INSRSlate}{HTML}{F8F9FA}
\definecolor{INSRGraphite}{HTML}{343A40}
\definecolor{INSRSoftRed}{HTML}{D9534F}
\definecolor{INSRSoftGreen}{HTML}{2E7D32}
\definecolor{INSRViolet}{HTML}{6F42C1}

\RequirePackage{microtype}
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{longtable}
\RequirePackage{array}
\@ifclassloaded{beamer}{}{\RequirePackage{enumitem}}
\RequirePackage{amsmath,amssymb,mathtools}
\RequirePackage{siunitx}
\sisetup{detect-all, per-mode=symbol}
\RequirePackage{csquotes}
\@ifclassloaded{beamer}{}{\RequirePackage{authblk}}
\RequirePackage[acronym,shortcuts,record=hybrid]{glossaries-extra}
\setabbreviationstyle[acronym]{long-short}
\RequirePackage{tikz}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\ifinsr@externalize
  \usetikzlibrary{external}
  \tikzexternalize[prefix=build/tikz/]
\fi
\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable}
\RequirePackage{hyperref}
\hypersetup{colorlinks=true,linkcolor=INSRNavy,citecolor=INSRTeal,urlcolor=INSRTeal,pdfauthor={INSR Research Consortium}}
\RequirePackage[nameinlink,noabbrev]{cleveref}
\RequirePackage[style=apa,backend=biber,sortcites=true,uniquename=false]{biblatex}

\ifinsr@python
  \IfFileExists{pyluatex.sty}{\RequirePackage{pyluatex}}{\PackageWarning{insr-base}{pyluatex.sty not found; Python execution macros will be unavailable}}
\fi
\ifinsr@minted
  \IfFileExists{minted.sty}{\RequirePackage{minted}}{\PackageWarning{insr-base}{minted.sty not found; code highlighting will be unavailable}}
\fi
\ifinsr@review
  \IfFileExists{todonotes.sty}{\RequirePackage{xargs}\RequirePackage{todonotes}}{\PackageWarning{insr-base}{todonotes.sty not found; review todo commands will fall back to inline notes}}
\fi

\newcommand{\INSRName}{Integrative Neuro-Somatic Recalibration}
\newcommand{\INSRShort}{INSR}
\newcommand{\INSRTagline}{Precision trauma research with human-governed neuro-somatic state calibration}
\newcommand{\INSRCorrespondence}[1]{\def\insr@correspondence{#1}}
\newcommand{\insr@correspondence}{}
\newcommand{\INSRKeywords}[1]{\par\noindent\textbf{Keywords:} #1\par}

\newcommand{\INSRAddAuthor}[3][]{%
  \@ifclassloaded{beamer}{%
    \ifinsr@blindreview
      \author{Anonymous Author}%
      \institute{Institution withheld for blind review}%
    \else
      \if\relax\detokenize{#1}\relax\author{#2}\else\author[#1]{#2}\fi
      \institute{#3}%
    \fi
  }{%
    \ifinsr@blindreview
      \author[ ]{Anonymous Author}%
      \affil[ ]{Institution withheld for blind review}%
    \else
      \author[#1]{#2}%
      \affil[#1]{#3}%
    \fi
  }}

\newcommand{\INSRClinicalStop}[1]{\textcolor{INSRSoftRed}{\textbf{Clinical hard-stop:} #1}}
\newcommand{\INSRSomaticHold}[1]{\textcolor{INSRAmber}{\textbf{Somatic hold:} #1}}
\newcommand{\INSRHumanLoop}{\textbf{Human-in-the-loop CDSS}}

\newtcolorbox{insrbox}[2][]{enhanced,breakable,colback=INSRSlate,colframe=INSRNavy,title=#2,fonttitle=\bfseries,coltitle=white,#1}
\newtcolorbox{insralert}[2][]{enhanced,breakable,colback=INSRAmber!12,colframe=INSRAmber!80!black,title=#2,fonttitle=\bfseries,coltitle=black,#1}
\newtcolorbox{insrclinical}[2][]{enhanced,breakable,colback=INSRSoftRed!6,colframe=INSRSoftRed,title=#2,fonttitle=\bfseries,coltitle=white,#1}
\newtcolorbox{insrmethod}[2][]{enhanced,breakable,colback=INSRTeal!6,colframe=INSRTeal,title=#2,fonttitle=\bfseries,coltitle=white,#1}

\newcommand{\INSRReviewNote}[2][INSRTeal]{\textcolor{#1}{\textbf{[#2]}}}
\makeatletter
\@ifpackageloaded{todonotes}{%
  \newcommandx{\INSRTodoClinical}[2][1=]{\todo[linecolor=INSRSoftRed,backgroundcolor=INSRSoftRed!12,bordercolor=INSRSoftRed,#1]{Clinical: #2}}%
  \newcommandx{\INSRTodoBiostats}[2][1=]{\todo[linecolor=INSRTeal,backgroundcolor=INSRTeal!12,bordercolor=INSRTeal,#1]{Biostats: #2}}%
  \newcommandx{\INSRTodoTech}[2][1=]{\todo[linecolor=INSRViolet,backgroundcolor=INSRViolet!12,bordercolor=INSRViolet,#1]{Tech: #2}}%
}{%
  \newcommand{\INSRTodoClinical}[2][]{\INSRReviewNote[INSRSoftRed]{Clinical: #2}}%
  \newcommand{\INSRTodoBiostats}[2][]{\INSRReviewNote[INSRTeal]{Biostats: #2}}%
  \newcommand{\INSRTodoTech}[2][]{\INSRReviewNote[INSRViolet]{Tech: #2}}%
}
\makeatother
\newcommand{\INSRFidelityCheck}[1]{\par\noindent$\square$\,#1\par}

\newacronym{insr}{INSR}{Integrative Neuro-Somatic Recalibration}
\newacronym{cptsd}{C-PTSD}{Complex Posttraumatic Stress Disorder}
\newacronym{dso}{DSO}{Disturbances in Self-Organization}
\newacronym{hrv}{HRV}{heart-rate variability}
\newacronym{rmssd}{RMSSD}{root mean square of successive differences}
\newacronym{eda}{EDA}{electrodermal activity}
\newacronym{tdcs}{tDCS}{transcranial direct-current stimulation}
\newacronym{cdss}{CDSS}{Clinical Decision Support System}
\newacronym{mdr}{MDR}{Medical Device Regulation}
\newacronym{itq}{ITQ}{International Trauma Questionnaire}
\newacronym{caps}{CAPS-5}{Clinician-Administered PTSD Scale for DSM-5}
