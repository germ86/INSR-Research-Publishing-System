\input{regression-test.tex}
\START
\RequirePackage{insr-core}
\INSRRegisterPlugin{needs-missing}{dependencies=missing-plugin}
\INSRRegisterPlugin{cycle-a}{dependencies=cycle-b}
\INSRRegisterPlugin{cycle-b}{dependencies=cycle-a}
\INSRRegisterPlugin{old-core}{min-core-version=999.0.0}
\INSRRegisterPlugin{conflict-a}{conflicts=conflict-b}
\INSRRegisterPlugin{conflict-b}{}
\INSRUsePlugin{needs-missing}
\INSRUsePlugin{cycle-a}
\INSRUsePlugin{old-core}
\INSRUsePlugin{conflict-b}
\INSRUsePlugin{conflict-a}
\END
